{
  "name": "gigatt-driver-app",
  "version": "1.0.0",
  "description": "GIGATT Geomapper driver portal — Capacitor iOS/Android. Plan Phase 4.",
  "scripts": {
    "build": "node scripts/sync-web.js",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "capacitor": {
    "dist": {
      "android": {
        "path": "android"
      },
      "ios": {
        "path": "ios"
      }
    }
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "1.2.26",
    "@capacitor/geolocation": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "typescript": "^5.9.3"
  },
  "capabilities": {
    "plugins": {
      "Geolocation": {},
      "App": {}
    }
  }
}
