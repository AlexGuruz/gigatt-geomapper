# Copy to .env and fill in. Do not commit .env.
# For local dev, backend also loads from backend/secrets_loader (Guru Config, Supabase Pass) if present.

PORT=8080
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional: path to directory containing Guru Config.json and Supabase Pass.json
# SECRETS_DIR=E:\secrets\gcp
